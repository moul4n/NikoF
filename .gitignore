# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Local-only bootstrap outputs and repo-adjacent fallback roots
.local/
/.cache/
/cache/
/models/
/providers/

# Stability harness run artifacts
tests/stability/artifacts/current/*
!tests/stability/artifacts/current/.gitkeep
tests/stability/artifacts/reports/*
!tests/stability/artifacts/reports/.gitkeep

# Machine-local env files
.env.local
.env.*.local

# Common local Python envs for bootstrap or backend work
backend/.venv/
.venv/

# Python cache artifacts
__pycache__/
*.pyc
*.pyo

# Frontend install and build outputs
frontend/node_modules/
frontend/dist/

# Raw animation sources are tracked for now; keep JSON/DSL outputs in git as the
# semantic staging path for provenance and later promotion work.
