{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nikof.local/schemas/session-event.schema.json",
  "title": "Session Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_type",
    "session_id",
    "character_id",
    "status",
    "timestamp"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "session.state",
        "session.character.selected",
        "session.started",
        "session.stopped",
        "transcription.status",
        "assistant.message",
        "speech.synthesis",
        "animation.play"
      ]
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "character_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  }
}